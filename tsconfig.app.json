{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["vite/client"],

    // ✅ ALIAS (IMPORTANT)
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    // ✅ STABILITY FIX (TS 2025+)
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
